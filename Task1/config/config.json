{
    "model": {
        "model_id": "gemma2:9b",
        "timeout": 1200,
        "max_retries": 3,
        "retry_delay": 3
    },
    "output": {
        "output_file": "output/sales_report_gemma13.json"
    },
    "text_splitter": {
        "chunk_size": 2500,
        "chunk_overlap": 500
    },
    "settings": {
        "verbose": true,
        "use_fallback_regex": true,
        "max_heading_length": 100
    },
    "heading_detection": {
        "level_1_keywords": [
            "chapter", "part", "appendix", "abstract", "introduction",
            "conclusion", "references", "bibliography", "acknowledgements",
            "acknowledgments", "preface", "foreword", "glossary", "index"
        ],
        "false_heading_patterns": [
            "^Figure\\s+\\d+",
            "^Fig\\.?\\s+\\d+",
            "^Table\\s+\\d+",
            "^Equation\\s+\\d+",
            "^Algorithm\\s+\\d+",
            "^Listing\\s+\\d+",
            "^Theorem\\s+\\d+",
            "^Lemma\\s+\\d+",
            "^Definition\\s+\\d+",
            "^Example\\s+\\d+:",
            "^Note:",
            "^Source:",
            "^DOI:",
            "^ISBN",
            "^ISSN",
            "^\\d+\\s*$",
            "^Page\\s+\\d+",
            "^·\\s",
            "^•\\s",
            "^-\\s",
            "^\\*\\s",
            "^Thesis$",
            "^Thesis\\s+[·•]\\s+",
            "^CITATIONS$",
            "^READS$",
            "^SEE PROFILE$",
            "^View publication",
            "^All content following",
            "^\\.+$",
            "^http",
            "^www\\.",
            "@.*\\.com",
            "^Walking through",
            "^The used code",
            "^We (have|want|used|tried|hope)",
            "^In (this|the|our)",
            "^For (the|a|example)",
            "^And (for|then)",
            "^As (an|in|a)",
            "^\\[\\d+\\]",
            "^\\(\\d+\\)",
            "^By:$",
            "^.*Supervisor:$",
            "^.*Supervisor$",
            "^Damascus\\s+\\d{4}",
            "^\\d{4}[-–]\\d{4}$",
            "^[A-Z][a-z]+\\s+\\d{4}$",
            ".*·.*\\d{4}",
            "^List of (figures|tables)$"
        ]
    }
}
